# ──────────────────────────────────────────────────────────────────────────────
# Renov-AI — Server Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (required for production)
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/renovai?retryWrites=true&w=majority
# Get it from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb://localhost:27017/renovai

# ── Authentication ────────────────────────────────────────────────────────────
# MUST be a long, random, secret string in production (min 32 chars)
# Generate one: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── ML Service ────────────────────────────────────────────────────────────────
# URL where the Flask ML microservice is running
# Local: http://localhost:5001
# Production (Render): https://renovai-ml.onrender.com
ML_SERVICE_URL=http://localhost:5001

# ── OpenAI (Optional) ─────────────────────────────────────────────────────────
# Used for AI-powered design suggestions (/api/design endpoint)
# If not set, the app falls back to rule-based design templates (still works!)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your frontend URL in production to restrict CORS
# Example: https://renovai-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
