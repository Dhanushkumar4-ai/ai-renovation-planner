# ──────────────────────────────────────────────────────────────────────────────
# Renov-AI — Frontend Environment Variables
# Copy this to .env (local) or set in your hosting platform dashboard
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Local dev: http://localhost:3001/api   (or just /api if using Vite proxy)
# Production: https://renovai-server.onrender.com/api
VITE_API_BASE_URL=/api
